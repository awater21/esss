local GetThreadIdentity =
    getthreadidentity
    or get_thread_identity
    or getidentity

local SetThreadIdentity =
    setthreadidentity
    or set_thread_identity
    or setidentity

local function runAtGameIdentity(callback, ...)
    local arguments = table.pack(...)
    local previousIdentity
    local identityChanged = false

    if type(SetThreadIdentity) == "function" then
        if type(GetThreadIdentity) == "function" then
            local ok, identity = pcall(GetThreadIdentity)

            if ok then
                previousIdentity = identity
            end
        end

        identityChanged = pcall(SetThreadIdentity, 2)
    end

    local results = table.pack(pcall(function()
        return callback(table.unpack(arguments, 1, arguments.n))
    end))

    if identityChanged and previousIdentity ~= nil then
        pcall(SetThreadIdentity, previousIdentity)
    end

    if not results[1] then
        error(results[2], 0)
    end

    return table.unpack(results, 2, results.n)
end

local function safeRequire(module, moduleName)
    local maxAttempts = 8
    local retryDelay = 1
    local requireFunctions = {}
    local seenRequireFunctions = {}

    local function addRequireFunction(requireFunction)
        if type(requireFunction) == "function" and not seenRequireFunctions[requireFunction] then
            seenRequireFunctions[requireFunction] = true
            table.insert(requireFunctions, requireFunction)
        end
    end

    if type(getrenv) == "function" then
        local ok, robloxEnvironment = pcall(getrenv)

        if ok and type(robloxEnvironment) == "table" then
            addRequireFunction(rawget(robloxEnvironment, "require"))
        end
    end

    addRequireFunction(require)

    if type(getgenv) == "function" then
        local ok, globalEnvironment = pcall(getgenv)

        if ok and type(globalEnvironment) == "table" then
            addRequireFunction(rawget(globalEnvironment, "require"))
        end
    end

    moduleName = moduleName or (typeof(module) == "Instance" and module:GetFullName()) or tostring(module)

    if typeof(module) ~= "Instance" or not module:IsA("ModuleScript") then
        error(("[BSS Webhook Tracker] %s is not a ModuleScript."):format(moduleName), 2)
    end

    local lastError = "Unknown require error"

    for attempt = 1, maxAttempts do
        if not module:IsDescendantOf(game) then
            lastError = "ModuleScript is not currently parented under the game."
        else
            for _, requireFunction in ipairs(requireFunctions) do
                local ok, result = pcall(function()
                    return runAtGameIdentity(requireFunction, module)
                end)

                if ok then
                    return result
                end

                lastError = result
            end
        end

        if attempt < maxAttempts then
            warn(("[BSS Webhook Tracker] Failed to require %s (%d/%d): %s. Retrying..."):format(
                moduleName,
                attempt,
                maxAttempts,
                tostring(lastError)
            ))
            task.wait(retryDelay)
        end
    end

    error(("[BSS Webhook Tracker] Could not require %s after %d attempts: %s"):format(
        moduleName,
        maxAttempts,
        tostring(lastError)
    ), 2)
end

